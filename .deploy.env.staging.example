# Staging — copy to .deploy.env on the staging server, fill in real secrets.

# --- Required ---
SECRET_KEY=                                   # python -c "import secrets; print(secrets.token_hex(32))"
DATABASE_URL=postgresql://traiteurs:CHANGE_ME_DB_PASSWORD@db:5432/traiteurs

# --- Caddy / TLS ---
CADDY_DOMAIN=staging.traiteurs.engages.inclusion.gouv.fr
CADDY_ACME_EMAIL=ops@inclusion.gouv.fr

# --- Networking ---
HOST_BIND=127.0.0.1                           # Only Caddy reaches the app
HOST_PORT=8000
COMPOSE_PROJECT_NAME=traiteurs-staging

# --- Cookie / proxy hardening (mandatory once Caddy is in front) ---
SECURE_COOKIES=true
TRUST_PROXY_HEADERS=true

# --- First-boot admin (clear once `flask admin create` has been run once) ---
ADMIN_EMAIL=admin@inclusion.gouv.fr
ADMIN_INITIAL_PASSWORD=                       # leave empty after first boot

# --- Stripe (test keys for staging) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_CLIENT_ID=ca_...

# --- Demo data (true on staging for QA, MUST be empty on prod) ---
ENABLE_DEMO_SEED=1

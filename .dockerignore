# VCS
.git/
.gitignore
.gitattributes

# Secrets / env
.env
.env.*
*.pem
*.key

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
*.egg-info/

# SQLite local
*.db
*.sqlite
*.sqlite3

# IDE / OS
.idea/
.vscode/
.DS_Store
Thumbs.db

# Test / coverage (tests/ stays in the image — README recommends running
# `docker compose exec app pytest` for QA against the live container).
.pytest_cache/
.coverage
htmlcov/

# Build artefacts
dist/
build/

# Docs / specs not needed at runtime
*.md
.specify/
plan.md
spec.md
tasks.md

# Local notes
.claude/

# Local-only compose overrides (not used in any deployment)
docker-compose.local.yml

# Dev-only fixture seeder + demo helpers. Audit C-3 (2026-05-13): even
# though seed() now refuses to run outside FLASK_DEBUG=1 /
# SEED_FIXTURES_ALLOW=1, keeping these out of the prod image is one
# extra layer between a compromised Scalingo console and the demo
# accounts they create.
seed_data.py
scripts/

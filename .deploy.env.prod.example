# Production — copy to .deploy.env on the production server, fill in real secrets.
# NEVER commit this file with real values.

# --- Required ---
SECRET_KEY=                                   # python -c "import secrets; print(secrets.token_hex(32))"
DATABASE_URL=postgresql://traiteurs:CHANGE_ME_DB_PASSWORD@db:5432/traiteurs

# --- Caddy / TLS ---
CADDY_DOMAIN=traiteurs.engages.inclusion.gouv.fr
CADDY_ACME_EMAIL=ops@inclusion.gouv.fr

# --- Networking ---
HOST_BIND=127.0.0.1                           # Only Caddy reaches the app
HOST_PORT=8000
COMPOSE_PROJECT_NAME=traiteurs-prod

# --- Cookie / proxy hardening (MANDATORY in prod) ---
SECURE_COOKIES=true
TRUST_PROXY_HEADERS=true

# --- First-boot admin (clear after `flask admin create`) ---
ADMIN_EMAIL=admin@inclusion.gouv.fr
ADMIN_INITIAL_PASSWORD=                       # leave EMPTY in prod after first boot

# --- Stripe (LIVE keys — handle with care) ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_CLIENT_ID=ca_...

# --- Demo data MUST be empty in production ---
ENABLE_DEMO_SEED=

# --- Synthetic.new (LLM provider, OpenAI-compatible API) ---
# In prod, request a dedicated key from the infra lead — do NOT reuse the
# shared POC key. Not consumed by the codebase yet; populated here so
# future LLM features can read it via os.getenv.
SYNTHETIC_API_URL=https://api.synthetic.new/openai/v1
SYNTHETIC_API_KEY=

# Copy to .deploy.env and fill in real values. .deploy.env is gitignored.

# Required
SECRET_KEY=                   # generate with: python -c 'import secrets; print(secrets.token_hex(32))'
DATABASE_URL=postgresql://user:pass@db:5432/traiteurs

# Optional — first super-admin bootstrap
ADMIN_EMAIL=admin@example.com
ADMIN_INITIAL_PASSWORD=       # leave empty to skip seeding the admin

# Stripe (leave empty to disable Stripe features)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=

# Compose
HOST_PORT=8000
COMPOSE_PROJECT_NAME=traiteurs

# Copy to .deploy.env and fill in real values. .deploy.env is gitignored.

# Required
SECRET_KEY=                   # generate with: python -c 'import secrets; print(secrets.token_hex(32))'
DATABASE_URL=postgresql://user:pass@db:5432/traiteurs

# Optional — first super-admin bootstrap
ADMIN_EMAIL=admin@example.com
ADMIN_INITIAL_PASSWORD=       # leave empty to skip seeding the admin

# Stripe (leave empty to disable Stripe features)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=

# Production hardening — flip both to true when a reverse proxy (Caddy,
# Nginx, Traefik, Scaleway Serverless Containers edge, managed CDN) is in
# front of the app terminating TLS.
#
# SECURE_COOKIES without TLS will log everyone out.
# TRUST_PROXY_HEADERS without a proxy in front lets clients spoof their IP.
SECURE_COOKIES=
TRUST_PROXY_HEADERS=

# S3-compatible object storage (leave empty for local disk in dev)
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT_URL=
S3_PUBLIC_URL=

# Brevo (transactional email). Leave BREVO_API_KEY empty in dev/test —
# services.email will then log the email payload to stderr instead of
# calling the API. Set MAIL_FROM_EMAIL to an address validated in Brevo
# (DKIM/SPF aligned with the domain's DNS) for prod.
BREVO_API_KEY=
MAIL_FROM_EMAIL=noreply@les-traiteurs-engages.fr
MAIL_FROM_NAME=Les Traiteurs Engagés
# Absolute origin used in email links (password-reset URL, etc.)
BASE_URL=http://localhost:8000

# Compose
HOST_PORT=8000
COMPOSE_PROJECT_NAME=traiteurs
